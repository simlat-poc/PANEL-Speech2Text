# Virtual environment (create fresh on each machine)
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local outputs and temp (adjust if you want to track small samples)
Outputs/
*.wav
*.mp4
*.mkv
!**/fixtures/**

# Local model / diarization caches (large)
.model_cache/

# Local voiceprint DB (embeddings + index)
.voiceprints/

# Local recordings / reference audio (often personal)
Users_records/

# Bundled ffmpeg distribution (large binaries)
ffmpeg-8.1-essentials_build/

# Local input media you don't want to track
Inputs/*.m4a
Inputs/*.mp3

# Secrets — never commit tokens
.env
.env.local
*.pem
# Local command cheatsheets that often contain pasted tokens
Inputs/Execution.local.txt

# PyInstaller / local builds
*.spec.bak
offline_assets/
offline_wheels/
delivery_bundle/
dist/
build/
Outputs/
Inputs/*.mp3
